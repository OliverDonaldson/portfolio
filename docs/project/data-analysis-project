    <script>
        // ─── Theme Toggle ───
        const themeToggle = document.getElementById('themeToggle');
        const root = document.documentElement;
        
        function setTheme(isDark) {
            root.setAttribute('data-theme', isDark ? 'dark' : 'light');
            localStorage.setItem('theme', isDark ? 'dark' : 'light');
        }

        // Default to dark theme
        const savedTheme = localStorage.getItem('theme') || 'dark';
        setTheme(savedTheme === 'dark');
        
        themeToggle.addEventListener('click', () => {
            const isDark = root.getAttribute('data-theme') === 'dark';
            setTheme(!isDark);
        });

        // ─── Mobile Menu ───
        const mobileMenuBtn = document.getElementById('mobileMenuBtn');
        const mobileNavOverlay = document.getElementById('mobileNavOverlay');
        
        mobileMenuBtn.addEventListener('click', () => {
            mobileMenuBtn.classList.toggle('active');
            mobileNavOverlay.classList.toggle('active');
            document.body.classList.toggle('no-scroll');
        });
        
        document.querySelectorAll('.mobile-nav-link').forEach(link => {
            link.addEventListener('click', () => {
                mobileMenuBtn.classList.remove('active');
                mobileNavOverlay.classList.remove('active');
                document.body.classList.remove('no-scroll');
            });
        });

        // ─── Slideshow ───
        let current = 0; 
        let slides = [];
        let dots = [];
        let slideInterval;
        let isPaused = false;
        let isAnimating = false;
            
        document.addEventListener("DOMContentLoaded", () => {
            slides = Array.from(document.getElementsByClassName("mySlides"));
            dots   = Array.from(document.getElementsByClassName("dot"));

            if (!slides.length) return;
        
            slides.forEach(s => s.classList.remove('is-current','is-entering','is-exiting'));
            slides[0].classList.add('is-current');
            
            if (dots.length) {
                dots.forEach(d => d.classList.remove('active'));
                dots[0].classList.add('active');
            }
        
            startSlideshow();
        });

        function startSlideshow() {
            if (slideInterval) clearInterval(slideInterval);
            slideInterval = setInterval(() => {
                if (!isPaused && !isAnimating) {
                    nextSlide();
                }
            }, 4000);
        }

        function nextSlide() {
            if (isAnimating || slides.length <= 1) return;
            moveSlide((current + 1) % slides.length);
        }

        function prevSlide() {
            if (isAnimating || slides.length <= 1) return;
            moveSlide((current - 1 + slides.length) % slides.length);
        }

        function moveSlide(newIndex) {
            if (newIndex === current || isAnimating) return;
            
            isAnimating = true;
            const oldSlide = slides[current];
            const newSlide = slides[newIndex];
            
            oldSlide.classList.add('is-exiting');
            newSlide.classList.add('is-entering');
            
            setTimeout(() => {
                oldSlide.classList.remove('is-current', 'is-exiting');
                newSlide.classList.remove('is-entering');
                newSlide.classList.add('is-current');
                
                if (dots.length) {
                    dots[current].classList.remove('active');
                    dots[newIndex].classList.add('active');
                }
                
                current = newIndex;
                isAnimating = false;
            }, 600);
        }

        function currentSlide(n) {
            moveSlide(n - 1);
        }

        // Pause on hover
        document.addEventListener("DOMContentLoaded", () => {
            const container = document.querySelector('.slideshow-container');
            if (container) {
                container.addEventListener('mouseenter', () => { isPaused = true; });
                container.addEventListener('mouseleave', () => { isPaused = false; });
            }
        });

        // ─── Scroll Animations ───
        function isElementInViewport(el) {
            const rect = el.getBoundingClientRect();
            return rect.top >= 0 && rect.top <= (window.innerHeight || document.documentElement.clientHeight);
        }

        function isElementPartiallyVisible(el) {
            const rect = el.getBoundingClientRect();
            return rect.top < (window.innerHeight || document.documentElement.clientHeight) && rect.bottom > 0;
        }

        function checkScrollAnimations() {
            document.querySelectorAll('.fade-in-up').forEach(el => {
                if (isElementPartiallyVisible(el)) el.classList.add('show');
            });

            document.querySelectorAll('.project-card').forEach(card => {
                if (isElementPartiallyVisible(card)) card.classList.add('visible');
            });

            document.querySelectorAll('.activity-card').forEach(card => {
                if (isElementPartiallyVisible(card)) card.classList.add('visible');
            });

            // Animate stats numbers
            document.querySelectorAll('.stat-number[data-target]').forEach(stat => {
                if (isElementPartiallyVisible(stat) && !stat.classList.contains('counted')) {
                    stat.classList.add('counted');
                    animateCounter(stat);
                }
            });
        }

        function animateCounter(el) {
            const target = parseInt(el.getAttribute('data-target'));
            const duration = 2000;
            const start = performance.now();
            
            function update(now) {
                const elapsed = now - start;
                const progress = Math.min(elapsed / duration, 1);
                const eased = 1 - Math.pow(1 - progress, 3);
                el.textContent = Math.floor(target * eased) + '+';
                if (progress < 1) requestAnimationFrame(update);
            }
            requestAnimationFrame(update);
        }

        window.addEventListener('scroll', checkScrollAnimations);
        document.addEventListener('DOMContentLoaded', checkScrollAnimations);

        // ─── Smooth Scroll for anchor links ───
        document.querySelectorAll('a[href*="#"]').forEach(anchor => {
            anchor.addEventListener('click', function(e) {
                const href = this.getAttribute('href');
                const hashIndex = href.indexOf('#');
                if (hashIndex === -1) return;
                const targetId = href.substring(hashIndex + 1);
                const target = document.getElementById(targetId);
                if (target) {
                    e.preventDefault();
                    target.scrollIntoView({ behavior: 'smooth', block: 'start' });
                }
            });
        });
    </script>
